#include "w5500.h"

#include <string.h>

#include "global_state.h"   // STRATUM_MANAGER, SYSTEM_MODULE (your project)
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/event_groups.h"

#include "driver/gpio.h"
#include "driver/spi_master.h"

#include "esp_event.h"
#include "esp_log.h"
#include "esp_eth.h"
#include "esp_eth_mac.h"
#include "esp_eth_phy.h"
#include "esp_eth_mac_spi.h"
#include "esp_eth_netif_glue.h"
#include "esp_mac.h"

static const char *TAG_ETH = "w5500";

// Set to 0 to use polling mode (recommended if you don't need INT)
#ifndef W5500_USE_INT
#define W5500_USE_INT 1
#endif

W5500::W5500()
{
    // nop
}

void W5500::makeEthMacFromEfuse(uint8_t out_mac[6])
{
    uint8_t base_mac[6] = {0};
    esp_err_t err = esp_efuse_mac_get_default(base_mac);

    if (err != ESP_OK) {
        // Fallback: locally administered, unicast
        out_mac[0] = 0x02;
        out_mac[1] = 0x00;
        out_mac[2] = 0x00;
        out_mac[3] = 0x00;
        out_mac[4] = 0x00;
        out_mac[5] = 0x01;
        return;
    }

    memcpy(out_mac, base_mac, 6);

    // Ensure unicast (bit0 = 0) and locally administered (bit1 = 1)
    out_mac[0] = (out_mac[0] & 0xFE) | 0x02;

    // Differentiate from WiFi by toggling a low bit
    out_mac[5] ^= 0x01;
}

void W5500::setEthMac(esp_eth_handle_t eth_handle, const char *tag)
{
    uint8_t mac[6];
    makeEthMacFromEfuse(mac);

    ESP_ERROR_CHECK(esp_eth_ioctl(eth_handle, ETH_CMD_S_MAC_ADDR, mac));

    ESP_LOGW(tag, "ETH MAC: %02X:%02X:%02X:%02X:%02X:%02X",
             mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
}

void W5500::hwResetGpio(gpio_num_t rst)
{
    gpio_config_t io = {};
    io.intr_type = GPIO_INTR_DISABLE;
    io.mode = GPIO_MODE_OUTPUT;
    io.pin_bit_mask = 1ULL << rst;
    io.pull_down_en = GPIO_PULLDOWN_DISABLE;
    io.pull_up_en = GPIO_PULLUP_DISABLE;
    ESP_ERROR_CHECK(gpio_config(&io));

    gpio_set_level(rst, 0);
    vTaskDelay(pdMS_TO_TICKS(50));
    gpio_set_level(rst, 1);
    vTaskDelay(pdMS_TO_TICKS(200));
}

void W5500::setDefaultNetif(esp_netif_t *netif)
{
    if (!netif) {
        return;
    }

    esp_err_t err = esp_netif_set_default_netif(netif);
    if (err != ESP_OK) {
        ESP_LOGW(TAG_ETH, "esp_netif_set_default_netif failed: %s", esp_err_to_name(err));
    }
}

void W5500::onLinkUp()
{
    ESP_LOGW(TAG_ETH, "ETH link UP");
    if (m_hookLinkUp) {
        m_hookLinkUp();
    }
}

void W5500::onLinkDown()
{
    ESP_LOGW(TAG_ETH, "ETH link DOWN");
    if (m_hookLinkDown) {
        m_hookLinkDown();
    }
}

void W5500::onGotIp()
{
    if (m_hookGotIp) {
        m_hookGotIp();
    }
}

void W5500::ethEventHandlerTrampoline(void *arg, esp_event_base_t base, int32_t id, void *data)
{
    (void)base;
    (void)data;
    W5500 *self = static_cast<W5500 *>(arg);
    if (self) {
        self->handleEthEvent(id);
    }
}

void W5500::ipEventHandlerTrampoline(void *arg, esp_event_base_t base, int32_t id, void *data)
{
    (void)base;
    W5500 *self = static_cast<W5500 *>(arg);
    if (self) {
        self->handleIpEvent(id, data);
    }
}

void W5500::linkMonitorTaskTrampoline(void *arg)
{
    W5500 *self = static_cast<W5500 *>(arg);
    if (self) {
        self->linkMonitorTask();
    }
    vTaskDelete(nullptr);
}

void W5500::handleEthEvent(int32_t id)
{
    switch (id) {
    case ETHERNET_EVENT_CONNECTED:
        ESP_LOGW(TAG_ETH, "ETHERNET_EVENT_CONNECTED");
        if (m_linkEg) {
            xEventGroupSetBits(m_linkEg, LINK_ETH_UP);
        }
        break;

    case ETHERNET_EVENT_DISCONNECTED:
        ESP_LOGW(TAG_ETH, "ETHERNET_EVENT_DISCONNECTED");
        if (m_linkEg) {
            xEventGroupClearBits(m_linkEg, LINK_ETH_UP);
        }
        break;

    case ETHERNET_EVENT_START:
        ESP_LOGW(TAG_ETH, "ETHERNET_EVENT_START");
        break;

    case ETHERNET_EVENT_STOP:
        ESP_LOGW(TAG_ETH, "ETHERNET_EVENT_STOP");
        break;

    default:
        break;
    }
}

void W5500::handleIpEvent(int32_t id, void *data)
{
    if (id != IP_EVENT_ETH_GOT_IP) {
        return;
    }

    const ip_event_got_ip_t *event = static_cast<const ip_event_got_ip_t *>(data);

    ESP_LOGW(TAG_ETH,
             "ETH GOT IP: " IPSTR "  MASK: " IPSTR "  GW: " IPSTR,
             IP2STR(&event->ip_info.ip),
             IP2STR(&event->ip_info.netmask),
             IP2STR(&event->ip_info.gw));

    // When DHCP is complete, prefer ETH as default route
    setDefaultNetif(m_ethNetif);

    onGotIp();

    // If you want the "reconnect now" behavior on GOT_IP:
    onLinkUp();
}

void W5500::linkMonitorTask()
{
    bool last_up = false;

    while (true) {
        EventBits_t bits = 0;
        if (m_linkEg) {
            bits = xEventGroupWaitBits(m_linkEg, LINK_ETH_UP, pdFALSE, pdFALSE, pdMS_TO_TICKS(1000));
        } else {
            vTaskDelay(pdMS_TO_TICKS(1000));
        }

        bool up = (bits & LINK_ETH_UP) != 0;

        if (up == last_up) {
            continue;
        }

        last_up = up;
        m_linkUp = up;

        if (!up) {
            // switch default route back to WiFi
            ESP_LOGW(TAG_ETH, "ETH down -> switch default route back to WiFi");
            if (SYSTEM_MODULE.getWifiInterface()) {
                setDefaultNetif(SYSTEM_MODULE.getWifiInterface());
            }
            onLinkDown();

            // Optional: reconnect on link down as well
            // if (STRATUM_MANAGER) { STRATUM_MANAGER->reconnectAll(); }
        } else {
            // IP event will be the "real" signal that ETH is usable
            ESP_LOGW(TAG_ETH, "ETH up -> waiting for DHCP/IP");
        }
    }
}

esp_err_t W5500::init()
{
    ESP_LOGW(TAG_ETH, "W5500::init start");

    if (!m_linkEg) {
        m_linkEg = xEventGroupCreate();
        if (!m_linkEg) {
            ESP_LOGE(TAG_ETH, "xEventGroupCreate failed");
            return ESP_FAIL;
        }
    }

    // Hardware reset (optional but nice)
    hwResetGpio(m_pinRst);

    // Create netif
    esp_netif_config_t netif_cfg = ESP_NETIF_DEFAULT_ETH();
    m_ethNetif = esp_netif_new(&netif_cfg);
    if (!m_ethNetif) {
        ESP_LOGE(TAG_ETH, "esp_netif_new(ETH) failed");
        return ESP_FAIL;
    }

    // SPI bus
    spi_bus_config_t buscfg = {};
    buscfg.mosi_io_num = m_pinMosi;
    buscfg.miso_io_num = m_pinMiso;
    buscfg.sclk_io_num = m_pinSclk;
    buscfg.quadwp_io_num = -1;
    buscfg.quadhd_io_num = -1;

    const spi_host_device_t spi_host = SPI2_HOST;

    esp_err_t err = spi_bus_initialize(spi_host, &buscfg, SPI_DMA_CH_AUTO);
    if (err != ESP_OK && err != ESP_ERR_INVALID_STATE) {
        ESP_LOGE(TAG_ETH, "spi_bus_initialize failed: %s", esp_err_to_name(err));
        return err;
    }

    // MAC/PHY config
    eth_mac_config_t mac_config = ETH_MAC_DEFAULT_CONFIG();
    eth_phy_config_t phy_config = ETH_PHY_DEFAULT_CONFIG();

    spi_device_interface_config_t spi_devcfg = {};
    spi_devcfg.command_bits = 16;                 // 16-bit address
    spi_devcfg.address_bits = 8;                  // 8-bit control
    spi_devcfg.dummy_bits = 0;
    spi_devcfg.mode = 0;
    spi_devcfg.clock_speed_hz = 2 * 1000 * 1000;  // start safe
    spi_devcfg.spics_io_num = m_pinCs;
    spi_devcfg.queue_size = 20;

    eth_w5500_config_t w5500_config = ETH_W5500_DEFAULT_CONFIG(spi_host, &spi_devcfg);

#if W5500_USE_INT
    w5500_config.int_gpio_num = m_pinInt;
#else
    w5500_config.int_gpio_num = -1;
    w5500_config.poll_period_ms = 1;
#endif

    esp_eth_mac_t *mac = esp_eth_mac_new_w5500(&w5500_config, &mac_config);
    if (!mac) {
        ESP_LOGE(TAG_ETH, "esp_eth_mac_new_w5500 failed");
        return ESP_FAIL;
    }

    esp_eth_phy_t *phy = esp_eth_phy_new_w5500(&phy_config);
    if (!phy) {
        ESP_LOGE(TAG_ETH, "esp_eth_phy_new_w5500 failed");
        mac->del(mac);
        return ESP_FAIL;
    }

    esp_eth_config_t eth_config = ETH_DEFAULT_CONFIG(mac, phy);

    err = esp_eth_driver_install(&eth_config, &m_ethHandle);
    if (err != ESP_OK || !m_ethHandle) {
        ESP_LOGE(TAG_ETH, "esp_eth_driver_install failed: %s (handle=%p)", esp_err_to_name(err), m_ethHandle);
        phy->del(phy);
        mac->del(mac);
        return (err != ESP_OK) ? err : ESP_FAIL;
    }

    setEthMac(m_ethHandle, TAG_ETH);

    esp_eth_netif_glue_handle_t glue = esp_eth_new_netif_glue(m_ethHandle);
    if (!glue) {
        ESP_LOGE(TAG_ETH, "esp_eth_new_netif_glue returned NULL (eth_handle=%p)", m_ethHandle);
        esp_eth_driver_uninstall(m_ethHandle);
        m_ethHandle = nullptr;
        return ESP_FAIL;
    }

    err = esp_netif_attach(m_ethNetif, glue);
    if (err != ESP_OK) {
        ESP_LOGE(TAG_ETH, "esp_netif_attach failed: %s", esp_err_to_name(err));
        esp_eth_driver_uninstall(m_ethHandle);
        m_ethHandle = nullptr;
        return err;
    }

    // Register handlers (pass `this` as arg)
    ESP_ERROR_CHECK(esp_event_handler_register(ETH_EVENT, ESP_EVENT_ANY_ID, &W5500::ethEventHandlerTrampoline, this));
    ESP_ERROR_CHECK(esp_event_handler_register(IP_EVENT, IP_EVENT_ETH_GOT_IP, &W5500::ipEventHandlerTrampoline, this));

    err = esp_eth_start(m_ethHandle);
    if (err != ESP_OK) {
        ESP_LOGE(TAG_ETH, "esp_eth_start failed: %s", esp_err_to_name(err));
        return err;
    }

    xTaskCreate(&W5500::linkMonitorTaskTrampoline, "eth link mon", 3072, this, 4, nullptr);

    ESP_LOGW(TAG_ETH, "W5500 init done");
    return ESP_OK;
}
